---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Orange Team',
    role: 'Core Contributors',
    description: 'Building clean, maintainable .NET services with modern tooling.',
  },
];

const techStack = [
  { name: '.NET 10', description: 'Modern, high-performance web framework', icon: '🔷' },
  { name: 'Clean Architecture', description: 'Layered architecture for maintainable code', icon: '🏗️' },
  { name: 'CQRS', description: 'Command Query Responsibility Segregation', icon: '🔄' },
  { name: 'Astro', description: 'Fast static-first web framework', icon: '🚀' },
  { name: 'Tailwind CSS', description: 'Utility-first CSS framework', icon: '🎨' },
  { name: 'TypeScript', description: 'Typed JavaScript for safer code', icon: '📘' },
];
---

<Layout title="About" description="About the Orange Clean Architecture Template">
  <div class="max-w-4xl">
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">About Orange 🍊</h1>
      <p class="text-lg text-gray-600 leading-relaxed">
        Orange is a GitHub repository template for building <strong class="text-gray-800">.NET 10 services</strong> following
        Clean Architecture principles. It provides a solid foundation for building scalable, maintainable, and testable applications.
      </p>
    </div>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-gray-800 mb-6">Technology Stack</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {techStack.map((tech) => (
          <div class="bg-white border border-gray-200 rounded-xl p-5 hover:shadow-md transition-shadow">
            <div class="text-2xl mb-2">{tech.icon}</div>
            <h3 class="font-semibold text-gray-800 mb-1">{tech.name}</h3>
            <p class="text-sm text-gray-500">{tech.description}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-gray-800 mb-6">Architecture Overview</h2>
      <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-gray-200">
          {[
            { layer: 'Domain', description: 'Core business entities, value objects, and interfaces', color: 'bg-purple-50', text: 'text-purple-700', border: 'border-purple-200' },
            { layer: 'Application', description: 'Use cases, CQRS commands/queries, and business rules', color: 'bg-blue-50', text: 'text-blue-700', border: 'border-blue-200' },
            { layer: 'Infrastructure', description: 'Database, external services, and repository implementations', color: 'bg-green-50', text: 'text-green-700', border: 'border-green-200' },
            { layer: 'API', description: 'Minimal API presentation layer with OpenAPI documentation', color: 'bg-orange-50', text: 'text-orange-700', border: 'border-orange-200' },
          ].map((item) => (
            <div class={`${item.color} p-5`}>
              <h3 class={`font-bold text-sm uppercase tracking-wider ${item.text} mb-2`}>{item.layer}</h3>
              <p class="text-xs text-gray-600 leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-semibold text-gray-800 mb-6">API Response Format</h2>
      <div class="bg-gray-900 rounded-xl p-6">
        <p class="text-gray-400 text-xs uppercase tracking-wider mb-3 font-mono">JSON</p>
        <pre class="text-green-400 font-mono text-sm leading-relaxed overflow-x-auto">{`{
  "data": [...],
  "total": 100,
  "page": 1,
  "pageSize": 10,
  "totalPages": 10
}`}</pre>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-semibold text-gray-800 mb-6">Getting Started</h2>
      <div class="space-y-4">
        <div class="bg-white border border-gray-200 rounded-xl p-6">
          <h3 class="font-semibold text-gray-800 mb-3">Prerequisites</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li class="flex items-center gap-2"><span class="text-green-500">✓</span> .NET 10 SDK</li>
            <li class="flex items-center gap-2"><span class="text-green-500">✓</span> Node.js 18+</li>
            <li class="flex items-center gap-2"><span class="text-green-500">✓</span> npm 9+</li>
          </ul>
        </div>
        <div class="bg-gray-900 rounded-xl p-6">
          <p class="text-gray-400 text-xs uppercase tracking-wider mb-3 font-mono">Terminal</p>
          <pre class="text-green-400 font-mono text-sm">{`# Run the API service
./run.sh

# Run the client
cd Client
npm install
npm run dev`}</pre>
        </div>
      </div>
    </section>
  </div>
</Layout>
