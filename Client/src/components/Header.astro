---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
];
const currentPath = Astro.url.pathname;
---

<header class="bg-orange-600 text-white shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center gap-3">
        <span class="text-2xl font-bold tracking-tight">🍊 Orange</span>
        <span class="hidden sm:block text-orange-200 text-sm">Clean Architecture Service</span>
      </div>
      <nav class="flex gap-4">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
              currentPath === item.href
                ? 'bg-orange-800 text-white'
                : 'text-orange-100 hover:bg-orange-500 hover:text-white'
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
