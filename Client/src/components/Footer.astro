---
const year = new Date().getFullYear();
---

<footer class="bg-gray-800 text-gray-300 py-6 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="text-orange-400 font-semibold">🍊 Orange</span>
        <span class="text-gray-500 text-sm">Clean Architecture Template</span>
      </div>
      <p class="text-sm text-gray-500">
        &copy; {year} Orange. Built with <a
          href="https://astro.build"
          class="text-orange-400 hover:text-orange-300 transition-colors"
          >Astro</a
        > &amp; <a
          href="https://tailwindcss.com"
          class="text-orange-400 hover:text-orange-300 transition-colors"
          >Tailwind CSS</a
        >.
      </p>
    </div>
  </div>
</footer>
